# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub!

# Your PostgreSQL connection string
# On Railway, this is auto-filled when you add a PostgreSQL plugin
DATABASE_URL=postgresql://username:password@localhost:5432/taskmanager

# Secret key for signing JWT tokens - make this long and random!
# You can generate one at: https://generate-secret.vercel.app/32
JWT_SECRET=your-super-secret-key-change-this-in-production

# The URL of your deployed frontend (for CORS)
FRONTEND_URL=http://localhost:3000

# Set to 'production' on Railway
NODE_ENV=development
